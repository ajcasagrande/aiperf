import asyncio
import uuid
from typing import cast

from pydantic import Field

from aiperf.common.aiperf_logger import AIPerfLogger
from aiperf.common.config import ServiceConfig, UserConfig
from aiperf.common.constants import DEFAULT_COMMAND_RESPONSE_TIMEOUT
from aiperf.common.enums import (
    CommandResponseStatus,
    MessageType,
)
from aiperf.common.hooks import on_message
from aiperf.common.messages import (
    CommandErrorResponse,
    CommandMessage,
    CommandResponse,
)
from aiperf.common.mixins.message_bus_mixin import MessageBusClientMixin
from aiperf.common.models.base_models import AIPerfBaseModel
from aiperf.common.models.error_models import ErrorDetails
# from aiperf.common.service_registry import ServiceRegistry
from aiperf.common.types import CommandTypeT

_logger = AIPerfLogger(__name__)


class TrackedCommand(AIPerfBaseModel):
    """Model for tracking a command and its responses."""

    command: CommandTypeT = Field(
        ...,
        description="The command that is being tracked",
    )
    command_id: str = Field(
        ...,
        description="The ID of the command that is being tracked",
    )
    sent_ns: int | None = Field(
        default=None,
        description="The time the command was sent, in nanoseconds. If None, the command was not sent yet.",
    )
    required_service_ids: set[str] = Field(
        ge=1,
        default_factory=set,
        description="The IDs of the services that are required to respond to the command",
    )
    timeout_seconds: float = Field(
        default=DEFAULT_COMMAND_RESPONSE_TIMEOUT,
        description="The timeout in seconds for the command",
    )
    responses: dict[str, CommandResponse] = Field(
        default_factory=dict,
        description="The responses to the command, keyed by the service ID of the responder",
    )
    allowed_statuses: set[CommandResponseStatus] = Field(
        default={
            CommandResponseStatus.SUCCESS,
            CommandResponseStatus.ACKNOWLEDGED,
            CommandResponseStatus.UNHANDLED,
        },
        description="The allowed response statuses for the command. If not provided, all statuses except for CommandResponseStatus.FAILURE are allowed.",
    )
    success: bool = Field(
        default=False,
        description="Whether the command was successful. If False, the command failed or timed out. If True, the command was successful.",
    )
    errors: dict[str, ErrorDetails] = Field(
        default_factory=dict,
        description="The errors for the command, keyed by the service ID of the responder",
    )

    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self._lock = asyncio.Lock()
        self._expected_count = len(self.required_service_ids)
        self._completed_event = asyncio.Event()

    async def store_response(self, response: CommandResponse) -> None:
        """Store a response to the command."""
        async with self._lock:
            if response.service_id in self.responses:
                _logger.warning(
                    f"Response from {response.service_id} already exists for command {self.command_id}"
                )
                return
            self.responses[response.service_id] = response
            if response.service_id in self.required_service_ids:
                self.required_service_ids.remove(response.service_id)
            if len(self.required_service_ids) == 0:
                self._completed_event.set()

    async def wait_for_responses(self) -> None:
        """Wait for the command to be responded to by all required services."""
        if self.sent_ns is None:
            raise ValueError("Command was not sent yet")
        try:
            await asyncio.wait_for(
                self._completed_event.wait(), timeout=self.timeout_seconds
            )
            self.success = True
        except asyncio.TimeoutError:
            _logger.warning(
                f"Command {self.command_id} timed out after {self.timeout_seconds} seconds"
            )
            self.success = False
        except Exception as e:
            _logger.error(f"Command {self.command_id} failed: {e}")
            self.success = False


class Commander(MessageBusClientMixin):
    """System Controller service.

    This service is responsible for managing the lifecycle of all other services.
    It will start, stop, and configure all other services.
    """

    def __init__(
        self,
        user_config: UserConfig,
        service_config: ServiceConfig,
        service_id: str | None = None,
    ) -> None:
        super().__init__(
            service_config=service_config,
            user_config=user_config,
            service_id=service_id,
        )
        self._tracked_commands: dict[str, TrackedCommand] = {}
        self._registry: ServiceRegistry = ServiceRegistry()

    async def send_command_with_tracking(self, command: CommandMessage) -> str:
        """Send a command and track the response."""
        command_id = str(uuid.uuid4())
        tracked_command = TrackedCommand(
            command=command.command,
            command_id=command_id,
            responses={},
        )
        self._tracked_commands[command_id] = tracked_command
        await self.publish(command)
        return command_id

    @on_message(
        lambda self: {
            f"{MessageType.COMMAND_RESPONSE}.{self.service_id}",
        }
    )
    async def _process_command_response_message(self, message: CommandResponse) -> None:
        """Process a command response message."""
        self.debug(lambda: f"Received command response message: {message}")
        if message.status == CommandResponseStatus.SUCCESS:
            self.debug(f"Command {message.command} succeeded from {message.service_id}")
        elif message.status == CommandResponseStatus.ACKNOWLEDGED:
            self.debug(
                f"Command {message.command} acknowledged from {message.service_id}"
            )
        elif message.status == CommandResponseStatus.UNHANDLED:
            self.debug(f"Command {message.command} unhandled from {message.service_id}")
        elif message.status == CommandResponseStatus.FAILURE:
            message = cast(CommandErrorResponse, message)
            self.error(
                f"Command {message.command} failed from {message.service_id}: {message.error}"
            )
