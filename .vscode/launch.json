{
    "configurations": [

        {
            "name": "aiperf",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/aiperf/cli.py",
            "args": [
                "profile",
                "-m",
                "deepseek-ai/DeepSeek-R1-Distill-Llama-8B",
                "--max-workers",
                "1",
                "--concurrency",
                "10"
            ],
            "env": {
            }
        },
        {
            "name": "scalene",
            "type": "scalene",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "module": "aiperf.cli",
            "args": [
                "-m", "deepseek-ai/DeepSeek-R1-Distill-Llama-8B"
            ],
            "env": {
                "AIPERF_ENABLE_UVLOOP": "True",
                "AIPERF_LOG_LEVEL": "DEBUG",
                "AIPERF_MAX_WORKERS": "1",
                "AIPERF_MIN_WORKERS": "1",
                "AIPERF_CONCURRENCY": "1",
                "AIPERF_TOTAL_REQUESTS": "10000",
                "AIPERF_DISABLE_UI": "true"
            }
        },
        {
            "name": "pytest",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "module": "pytest",
            "args": []
        }
    ],
    "version": "0.2.0"
}
