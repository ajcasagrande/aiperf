{
    "configurations": [
        {
            "name": "aiperf",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "module": "aiperf.cli",
            "args": [
                "profile",
                "-m",
                "deepseek-ai/DeepSeek-R1-Distill-Llama-8B",
                "--log-level",
                "DEBUG",
                "-u",
                "http://localhost:8000",
                "--max-workers",
                "1",
                "--record-processors",
                "0",
                "--streaming",
                "--concurrency",
                "5000",
                "--num-requests",
                "150000",
                "--random-seed",
                "100"
            ]
        },
        {
            "name": "pytest",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "module": "pytest",
            "args": ["-n", "auto"]
        }
    ],
    "version": "0.2.0"
}