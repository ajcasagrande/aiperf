SPDX-License-Identifier: Apache-2.0

VS Code Keybindings Template for AIPerf

To use this file:
1. Copy this file to your user settings:
   - Linux/macOS: ~/.config/Code/User/keybindings.json
   - Windows: %APPDATA%\Code\User\keybindings.json
2. Or merge these keybindings into your existing keybindings.json

Note: These are workspace-specific keybindings that only work when
the AIPerf project is open. You can modify them to suit your workflow.
*/
[
    // ============================================================
    // TASK SHORTCUTS
    // ============================================================

    // Testing
    {
        "key": "ctrl+shift+t",
        "command": "workbench.action.tasks.runTask",
        "args": "Test: Unit Tests",
        "when": "workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+alt+t",
        "command": "workbench.action.tasks.runTask",
        "args": "Test: Current File",
        "when": "editorTextFocus && resourceExtname == '.py'"
    },
    {
        "key": "ctrl+shift+f5",
        "command": "workbench.action.tasks.runTask",
        "args": "Test: Fast (Fail Fast)",
        "when": "workspaceFolderCount > 0"
    },

    // Code Quality
    {
        "key": "ctrl+shift+l",
        "command": "workbench.action.tasks.runTask",
        "args": "Lint: Check with Ruff",
        "when": "workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+shift+f",
        "command": "workbench.action.tasks.runTask",
        "args": "Format: Apply with Ruff",
        "when": "workspaceFolderCount > 0"
    },

    // Workflows
    {
        "key": "ctrl+shift+v",
        "command": "workbench.action.tasks.runTask",
        "args": "Workflow: Quick Validation",
        "when": "workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+alt+v",
        "command": "workbench.action.tasks.runTask",
        "args": "Workflow: Full Validation",
        "when": "workspaceFolderCount > 0"
    },

    // Documentation
    {
        "key": "ctrl+alt+d",
        "command": "workbench.action.tasks.runTask",
        "args": "Docs: Serve",
        "when": "workspaceFolderCount > 0"
    },

    // Coverage
    {
        "key": "ctrl+shift+c",
        "command": "workbench.action.tasks.runTask",
        "args": "Coverage: Generate Report",
        "when": "workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+alt+c",
        "command": "workbench.action.tasks.runTask",
        "args": "Coverage: Open HTML Report",
        "when": "workspaceFolderCount > 0"
    },

    // Mock Server
    {
        "key": "ctrl+alt+m",
        "command": "workbench.action.tasks.runTask",
        "args": "Mock Server: Start",
        "when": "workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+alt+shift+m",
        "command": "workbench.action.tasks.runTask",
        "args": "Mock Server: Stop",
        "when": "workspaceFolderCount > 0"
    },

    // ============================================================
    // DEBUGGING SHORTCUTS
    // ============================================================

    {
        "key": "f5",
        "command": "workbench.action.debug.start",
        "when": "debuggersAvailable && !inDebugMode"
    },
    {
        "key": "ctrl+f5",
        "command": "workbench.action.debug.run",
        "when": "debuggersAvailable && !inDebugMode"
    },
    {
        "key": "shift+f5",
        "command": "workbench.action.debug.stop",
        "when": "inDebugMode"
    },
    {
        "key": "f9",
        "command": "editor.debug.action.toggleBreakpoint",
        "when": "editorTextFocus"
    },
    {
        "key": "f10",
        "command": "workbench.action.debug.stepOver",
        "when": "inDebugMode"
    },
    {
        "key": "f11",
        "command": "workbench.action.debug.stepInto",
        "when": "inDebugMode"
    },
    {
        "key": "shift+f11",
        "command": "workbench.action.debug.stepOut",
        "when": "inDebugMode"
    },

    // ============================================================
    // TESTING PANEL SHORTCUTS
    // ============================================================

    {
        "key": "ctrl+; ctrl+t",
        "command": "workbench.view.testing.focus"
    },
    {
        "key": "ctrl+; ctrl+r",
        "command": "testing.runAll"
    },
    {
        "key": "ctrl+; ctrl+d",
        "command": "testing.debugAll"
    },
    {
        "key": "ctrl+; ctrl+c",
        "command": "testing.cancelRun"
    },

    // ============================================================
    // PROBLEMS PANEL SHORTCUTS
    // ============================================================

    {
        "key": "ctrl+shift+m",
        "command": "workbench.actions.view.problems"
    },
    {
        "key": "f8",
        "command": "editor.action.marker.nextInFiles",
        "when": "editorFocus"
    },
    {
        "key": "shift+f8",
        "command": "editor.action.marker.prevInFiles",
        "when": "editorFocus"
    },

    // ============================================================
    // TERMINAL SHORTCUTS
    // ============================================================

    {
        "key": "ctrl+`",
        "command": "workbench.action.terminal.toggleTerminal"
    },
    {
        "key": "ctrl+shift+`",
        "command": "workbench.action.terminal.new"
    },
    {
        "key": "ctrl+alt+`",
        "command": "workbench.action.terminal.kill"
    },

    // ============================================================
    // UTILITY SHORTCUTS
    // ============================================================

    {
        "key": "ctrl+k ctrl+c",
        "command": "workbench.action.tasks.runTask",
        "args": "Clean: Remove Caches",
        "when": "workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+k ctrl+i",
        "command": "workbench.action.tasks.runTask",
        "args": "Install: Project Dependencies",
        "when": "workspaceFolderCount > 0"
    },

    // ============================================================
    // QUICK OPEN SHORTCUTS
    // ============================================================

    {
        "key": "ctrl+p",
        "command": "workbench.action.quickOpen"
    },
    {
        "key": "ctrl+shift+p",
        "command": "workbench.action.showCommands"
    },
    {
        "key": "ctrl+shift+o",
        "command": "workbench.action.gotoSymbol"
    },

    // ============================================================
    // FILE NAVIGATION
    // ============================================================

    {
        "key": "ctrl+g",
        "command": "workbench.action.gotoLine"
    },
    {
        "key": "ctrl+t",
        "command": "workbench.action.showAllSymbols"
    },
    {
        "key": "alt+left",
        "command": "workbench.action.navigateBack"
    },
    {
        "key": "alt+right",
        "command": "workbench.action.navigateForward"
    },

    // ============================================================
    // EDITOR SHORTCUTS
    // ============================================================

    {
        "key": "ctrl+/",
        "command": "editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "shift+alt+f",
        "command": "editor.action.formatDocument",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+k ctrl+f",
        "command": "editor.action.formatSelection",
        "when": "editorHasSelection && editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+.",
        "command": "editor.action.quickFix",
        "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
    },
    {
        "key": "f12",
        "command": "editor.action.revealDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus"
    },
    {
        "key": "alt+f12",
        "command": "editor.action.peekDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus"
    },
    {
        "key": "shift+f12",
        "command": "editor.action.goToReferences",
        "when": "editorHasReferenceProvider && editorTextFocus"
    },
    {
        "key": "f2",
        "command": "editor.action.rename",
        "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
    },

    // ============================================================
    // GIT SHORTCUTS
    // ============================================================

    {
        "key": "ctrl+shift+g",
        "command": "workbench.view.scm"
    },
    {
        "key": "ctrl+k ctrl+g",
        "command": "git.openChange"
    },

    // ============================================================
    // CUSTOM SNIPPETS
    // ============================================================

    {
        "key": "ctrl+k ctrl+s",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && !editorReadonly"
    }
]
